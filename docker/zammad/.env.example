# Local development only. Copy to .env through scripts/zammad/configure.sh.
#
# Image versions mirror the official zammad/zammad-docker-compose v15.5.6
# release. Review the upstream release notes before changing any version.
VERSION=7.1.1-0020
IMAGE_REPO=ghcr.io/zammad/zammad
ELASTICSEARCH_VERSION=9.4.3
MEMCACHE_VERSION=1.6.44-alpine
POSTGRES_VERSION=17.10-alpine
REDIS_VERSION=8.8-alpine

TZ=Europe/Berlin
RESTART=unless-stopped
# Keep the local Zammad UI on the Docker host's loopback interface. Only
# override this deliberately when a protected reverse proxy is in front.
ZAMMAD_BIND_ADDRESS=127.0.0.1
ZAMMAD_FORWARD_PORT=8090
ZAMMAD_FQDN=localhost
ZAMMAD_HTTP_TYPE=http
NGINX_PORT=8080
NGINX_CLIENT_MAX_BODY_SIZE=25M

POSTGRES_DB=zammad_production
POSTGRES_USER=zammad
POSTGRES_PASS=CHANGE_ME
POSTGRESQL_OPTIONS=?pool=50

ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
ELASTICSEARCH_NAMESPACE=zammad
ELASTICSEARCH_REINDEX=true

BACKUP_TIME=03:00
HOLD_DAYS=10

# The existing Erin Compose project creates this network. Start Erin before
# starting Zammad, or override the exact network name if the project name was
# customized.
ERIN_DOCKER_NETWORK=erin_default

# Used only by the optional local bootstrap. Keep real values in the ignored
# docker/zammad/.env file, never in this template.
ZAMMAD_BOOTSTRAP_ADMIN_EMAIL=
ZAMMAD_BOOTSTRAP_ADMIN_PASSWORD=
ZAMMAD_INTEGRATION_EMAIL=
ZAMMAD_GROUP=Erin Support
ZAMMAD_WEBHOOK_CALLBACK_URL=http://laravel:8000/integrations/zammad/webhook
ZAMMAD_WEBHOOK_SECRET=CHANGE_ME

# AUTOWIZARD_JSON is generated as Base64 by configure.sh only when both admin
# values above are explicitly provided. Otherwise the browser setup wizard is
# shown on first access.
AUTOWIZARD_JSON=
