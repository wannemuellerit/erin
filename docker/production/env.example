ERIN_PILOT_PLAN_REFERENCE=
ERIN_PILOT_DECISION_REFERENCE=
ERIN_PILOT_ACCEPTANCE_REFERENCE=
ERIN_PILOT_ROLLBACK_REFERENCE=
ERIN_PILOT_STATUS=
ERIN_PILOT_SYNTHETIC=true
ERIN_PILOT_PARTICIPANT_CONSENT_VERIFIED=false
ERIN_PILOT_STOP_CRITERIA_TESTED=false
ERIN_PILOT_ROLLBACK_TESTED=false
ERIN_PILOT_EVIDENCE_MAX_AGE_DAYS=90
ERIN_GOVERNANCE_ATTESTATION_FILE=
ERIN_GOVERNANCE_TRUST_ROOT_FILE=
ERIN_GOVERNANCE_ATTESTATION_MAX_LIFETIME_HOURS=168

MAIL_HOST=
MAIL_PORT=587
MAIL_SCHEME=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@erin.example

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE=300
STRIPE_MAX_NETWORK_RETRIES=2
STRIPE_PRODUCT_BASIC=
STRIPE_PRICE_BASIC=
STRIPE_PRODUCT_BUSINESS=
STRIPE_PRICE_BUSINESS=
STRIPE_PRODUCT_PREMIUM=
STRIPE_PRICE_PREMIUM=
STRIPE_PRODUCT_RECRUITER_SEAT=
