APP_NAME=Erin
APP_ENV=production
APP_KEY=
APP_URL=https://erin.example
APP_DEBUG=false
APP_DEMO_MODE=false
APP_LOCALE=de
APP_FALLBACK_LOCALE=de
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=true
SESSION_SAME_SITE=lax
# Keep both values identical unless the deployed network topology is
# deliberately changed. Wildcards and /0 networks are rejected.
ERIN_INTERNAL_SUBNET=172.30.0.0/24
TRUSTED_PROXIES=172.30.0.0/24

# Build and deploy the PHP and Nginx images with the same full 40-character
# commit SHA. Moving tags such as latest/main/stable are not accepted.
ERIN_BUILD_SHA=
ERIN_APP_TAG=
# SHA-256 der exakten Trust-Root-JSON-Datei. Dieser Wert wird unveränderlich in
# das Image eingebaut und darf nicht erst zur Laufzeit ersetzt werden.
ERIN_GOVERNANCE_TRUST_ROOT_SHA256=

DB_DATABASE=erin
DB_USERNAME=erin
DB_PASSWORD=
DB_ROOT_PASSWORD=
REDIS_PASSWORD=
REDIS_QUEUE_RETRY_AFTER=180

REVERB_APP_ID=erin
REVERB_APP_KEY=
REVERB_APP_SECRET=
VITE_REVERB_HOST=erin.example
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
REVERB_ALLOWED_ORIGINS=erin.example
REVERB_APP_RATE_LIMITING_ENABLED=true
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=60
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60
REVERB_APP_RATE_LIMIT_TERMINATE=true

MEILISEARCH_KEY=
MINIO_ROOT_USER=erin-root
MINIO_ROOT_PASSWORD=
MINIO_APP_USER=erin-app
MINIO_APP_PASSWORD=
AWS_BUCKET=erin-private
AWS_DEFAULT_REGION=eu-central-1
PRIVATE_FILESYSTEM_DRIVER=s3
PRIVATE_FILESYSTEM_PREFIX=
CLAMAV_TIMEOUT=30

LOG_LEVEL=info
LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter

ERIN_QUEUE_HEALTH_QUEUES=high,default,low
ERIN_QUEUE_MAX_PENDING=500
ERIN_QUEUE_MAX_FAILED=0

# Zero leaves the corresponding deletion rule disabled. Set these values only
# after the approved retention schedule has been documented.
ERIN_RETENTION_LOGIN_HISTORY_DAYS=0
ERIN_RETENTION_READ_NOTIFICATION_DAYS=0
ERIN_RETENTION_ACTIVITY_DAYS=0
ERIN_RETENTION_CANDIDATE_IMPORT_DAYS=0
ERIN_RETENTION_FAILED_JOB_DAYS=0

# Release-bound evidence. Identities use "Vorname Nachname <mail@domain.tld>",
# dates use UTC ISO-8601, references point to immutable credential-free HTTPS.
ERIN_RELEASE_ID=
ERIN_RELEASE_COMMIT_SHA=
ERIN_RELEASE_PREPARED_BY=
ERIN_BACKUP_RESTORE_REFERENCE=
ERIN_BACKUP_RESTORE_VERIFIED_BY=
ERIN_BACKUP_RESTORE_VERIFIED_AT=
ERIN_BACKUP_DRILL_STARTED_AT=
ERIN_BACKUP_DRILL_COMPLETED_AT=
ERIN_BACKUP_DB_CREATED_AT=
ERIN_BACKUP_DB_LAST_RESTORED_RECORD_AT=
ERIN_BACKUP_DB_RESTORED_AT=
ERIN_BACKUP_OBJECT_CREATED_AT=
ERIN_BACKUP_OBJECT_LAST_RESTORED_RECORD_AT=
ERIN_BACKUP_OBJECT_RESTORED_AT=
ERIN_BACKUP_RESTORE_RELEASE_ID=
ERIN_BACKUP_DB_RPO_TARGET_MINUTES=
ERIN_BACKUP_DB_RPO_ACHIEVED_MINUTES=
ERIN_BACKUP_DB_RTO_TARGET_MINUTES=
ERIN_BACKUP_DB_RTO_ACHIEVED_MINUTES=
ERIN_BACKUP_OBJECT_RPO_TARGET_MINUTES=
ERIN_BACKUP_OBJECT_RPO_ACHIEVED_MINUTES=
ERIN_BACKUP_OBJECT_RTO_TARGET_MINUTES=
ERIN_BACKUP_OBJECT_RTO_ACHIEVED_MINUTES=
ERIN_BACKUP_ENCRYPTION_VERIFIED=false
ERIN_BACKUP_ISOLATION_VERIFIED=false
ERIN_BACKUP_SCOPE=
ERIN_BACKUP_PRODUCTION_GATE_ELIGIBLE=false
ERIN_BACKUP_INDEPENDENTLY_VERIFIED=false
ERIN_BACKUP_EVIDENCE_MAX_AGE_DAYS=90
ERIN_SECURITY_REVIEW_REFERENCE=
ERIN_SECURITY_REVIEWED_BY=
ERIN_SECURITY_REVIEWED_AT=
ERIN_SECURITY_REVIEW_RELEASE_ID=
ERIN_SECURITY_REVIEW_COMMIT_SHA=
ERIN_SECURITY_AUTOMATED_EVIDENCE_REFERENCE=
ERIN_SECURITY_OPEN_CRITICAL_FINDINGS=
ERIN_SECURITY_OPEN_HIGH_FINDINGS=
ERIN_SECURITY_INDEPENDENT_REVIEW_VERIFIED=false
ERIN_SECURITY_PENETRATION_TEST_VERIFIED=false
ERIN_SECURITY_EVIDENCE_MAX_AGE_DAYS=30
ERIN_DPO_APPROVAL_REFERENCE=
ERIN_DPO_APPROVED_BY=
ERIN_DPO_APPROVED_AT=
ERIN_DPO_APPROVAL_RELEASE_ID=
ERIN_DPO_APPROVAL_STATUS=
ERIN_DPO_AUTHORITY_VERIFIED=false
ERIN_DPO_EVIDENCE_MAX_AGE_DAYS=365
ERIN_LEGAL_APPROVAL_REFERENCE=
ERIN_LEGAL_APPROVED_BY=
