APP_NAME=Erin
APP_ENV=production
APP_KEY=
APP_URL=https://erin.example
APP_DEBUG=false
APP_DEMO_MODE=false
APP_LOCALE=de
APP_FALLBACK_LOCALE=en
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
# Safe with this stack because PHP-FPM is internal-only. Prefer explicit proxy
# CIDRs when PHP-FPM is reachable through a different network topology.
TRUSTED_PROXIES=*

DB_DATABASE=erin
DB_USERNAME=erin
DB_PASSWORD=
DB_ROOT_PASSWORD=
REDIS_PASSWORD=
REDIS_QUEUE_RETRY_AFTER=180

REVERB_APP_ID=erin
REVERB_APP_KEY=
REVERB_APP_SECRET=
VITE_REVERB_HOST=erin.example
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

MEILISEARCH_KEY=
MINIO_ROOT_USER=erin
MINIO_ROOT_PASSWORD=
AWS_BUCKET=erin-private
AWS_DEFAULT_REGION=eu-central-1
CLAMAV_TIMEOUT=30

LOG_LEVEL=info
LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter

ERIN_QUEUE_HEALTH_QUEUES=high,default,low
ERIN_QUEUE_MAX_PENDING=500
ERIN_QUEUE_MAX_FAILED=0

# Zero leaves the corresponding deletion rule disabled. Set these values only
# after the approved retention schedule has been documented.
ERIN_RETENTION_LOGIN_HISTORY_DAYS=0
ERIN_RETENTION_READ_NOTIFICATION_DAYS=0
ERIN_RETENTION_ACTIVITY_DAYS=0
ERIN_RETENTION_CANDIDATE_IMPORT_DAYS=0
ERIN_RETENTION_FAILED_JOB_DAYS=0

# Link to real evidence; placeholders must not pass the release gate.
ERIN_BACKUP_RESTORE_VERIFIED_AT=
ERIN_SECURITY_REVIEW_REFERENCE=
ERIN_DPO_APPROVAL_REFERENCE=
ERIN_LEGAL_APPROVAL_REFERENCE=
ERIN_PILOT_OWNER=

MAIL_HOST=
MAIL_PORT=587
MAIL_SCHEME=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@erin.example

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE=300
STRIPE_PRICE_BASIC=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_RECRUITER_SEAT=
STRIPE_PRICE_VISA_PACKAGE=
CASHIER_PATH=billing

ZAMMAD_ENABLED=false
ZAMMAD_URL=
ZAMMAD_TOKEN=
ZAMMAD_GROUP=Users
ZAMMAD_WEBHOOK_SECRET=
ZAMMAD_TIMEOUT=10

OPENAI_API_KEY=
OPENAI_PROJECT=
OPENAI_ORGANIZATION=
OPENAI_EU_DATA_CONTROLS=false
OPENAI_DOCUMENT_AI_ENABLED=false

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

VAPID_SUBJECT=mailto:no-reply@erin.example
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Optionaler einmaliger Bootstrap. Das Passwort ausschließlich als Deployment-
# Secret ERIN_BOOTSTRAP_ADMIN_PASSWORD setzen und nach erfolgreichem Lauf löschen.
ERIN_BOOTSTRAP_ADMIN_EMAIL=
ERIN_BOOTSTRAP_ADMIN_NAME=Erin Superadmin

ERIN_APP_IMAGE=erin-app
ERIN_NGINX_IMAGE=erin-nginx
ERIN_APP_TAG=latest
HTTP_PORT=80
