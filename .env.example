APP_NAME=Erin
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Europe/Berlin
APP_DEMO_MODE=true

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_DE

APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=redis

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=erin
DB_USERNAME=erin
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=180

CACHE_STORE=redis
CACHE_PREFIX=erin

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@wannemueller.dev"
MAIL_FROM_NAME="${APP_NAME}"

# Local MinIO credentials only. Replace these values for every non-local
# environment and use a secret manager in production.
MINIO_ROOT_USER=erin
MINIO_ROOT_PASSWORD=erin-local-password
AWS_ACCESS_KEY_ID="${MINIO_ROOT_USER}"
AWS_SECRET_ACCESS_KEY="${MINIO_ROOT_PASSWORD}"
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=erin-private
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000/erin-private
AWS_USE_PATH_STYLE_ENDPOINT=true

DOCUMENTS_DISK=documents
PRIVATE_FILESYSTEM_DRIVER=s3
DOCUMENTS_AWS_BUCKET="${AWS_BUCKET}"
DOCUMENTS_AWS_ENDPOINT="${AWS_ENDPOINT}"
DOCUMENTS_AWS_URL="${AWS_URL}"
DOCUMENTS_AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=erin
REVERB_APP_KEY=erin-local-key
REVERB_APP_SECRET=erin-local-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
VITE_BROADCAST_CONNECTION=reverb

# To use Pusher Channels instead of the local Reverb container:
# BROADCAST_CONNECTION=pusher
# VITE_BROADCAST_CONNECTION=pusher
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_HOST=
# PUSHER_PORT=443
# PUSHER_SCHEME=https
# PUSHER_APP_CLUSTER=mt1
# VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
# VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Stripe / Laravel Cashier. Product and Price IDs are created in Stripe and
# stored here; no product prices are hard-coded in the application.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE=300
STRIPE_PRICE_BASIC=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_RECRUITER_SEAT=
STRIPE_PRICE_VISA_PACKAGE=
VITE_STRIPE_PUBLISHABLE_KEY="${STRIPE_PUBLISHABLE_KEY}"
CASHIER_PATH=billing
CASHIER_CURRENCY=eur
CASHIER_CURRENCY_LOCALE=de_DE
CASHIER_PAPER=A4

# Zammad support bridge. The token belongs to a dedicated agent account.
# Configure the webhook URL as /integrations/zammad/webhook and use the same
# HMAC-SHA1 signature token on both sides.
ZAMMAD_ENABLED=false
ZAMMAD_URL=
ZAMMAD_TOKEN=
ZAMMAD_GROUP=Users
ZAMMAD_WEBHOOK_SECRET=
ZAMMAD_TIMEOUT=10

# Full-text search
SCOUT_DRIVER=meilisearch
SCOUT_PREFIX=erin_local_
SCOUT_QUEUE=true
SCOUT_AFTER_COMMIT=true
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=erin-local-master-key-change-me

# Private-file malware scanning
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=30

# OpenAI Responses API. Keep document processing disabled until the EU
# endpoint and the required data controls have been contractually enabled.
OPENAI_API_KEY=
OPENAI_PROJECT=
OPENAI_ORGANIZATION=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_QUALITY_MODEL=gpt-5.6-terra
OPENAI_ECONOMY_MODEL=gpt-5.6-luna
OPENAI_TIMEOUT=90
OPENAI_STORE=false
OPENAI_EU_DATA_CONTROLS=false
OPENAI_DOCUMENT_AI_ENABLED=false

# LiveKit Cloud. Use an EU-pinned project in production.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL_MINUTES=10
LIVEKIT_E2EE_REQUIRED=true
LIVEKIT_REGION=eu
VITE_LIVEKIT_URL="${LIVEKIT_URL}"

# Browser push. Generate VAPID keys per environment and never rotate them
# without migrating existing subscriptions.
VAPID_SUBJECT=mailto:noreply@wannemueller.dev
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
WEBPUSH_ALLOWED_ENDPOINT_HOSTS=fcm.googleapis.com,android.googleapis.com,updates.push.services.mozilla.com,push.services.mozilla.com,web.push.apple.com,notify.windows.com
VITE_VAPID_PUBLIC_KEY="${VAPID_PUBLIC_KEY}"

# Development service ports
APP_PORT=8000
VITE_PORT=5173
MYSQL_FORWARD_PORT=3306
REDIS_FORWARD_PORT=6379
REVERB_FORWARD_PORT=8080
MEILISEARCH_FORWARD_PORT=7700
MINIO_FORWARD_PORT=9000
MINIO_CONSOLE_FORWARD_PORT=9001
MAILPIT_FORWARD_PORT=8025
NGINX_FORWARD_PORT=8081
