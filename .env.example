APP_NAME=Erin
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Europe/Berlin
APP_DEMO_MODE=true

APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE

# Required only by compose.production.yaml. Use the full Git commit as both
# build SHA and immutable image tag; never use latest/main/stable.
ERIN_BUILD_SHA=
ERIN_APP_TAG=
ERIN_GOVERNANCE_TRUST_ROOT_SHA256=
ERIN_INTERNAL_SUBNET=172.30.0.0/24
TRUSTED_PROXIES=172.30.0.0/24

APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=redis

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=erin
DB_USERNAME=erin
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=180

CACHE_STORE=redis
CACHE_PREFIX=erin

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@wannemueller.dev"
MAIL_FROM_NAME="${APP_NAME}"

# Local MinIO credentials only. Replace these values for every non-local
# environment and use a secret manager in production.
MINIO_ROOT_USER=erin
MINIO_ROOT_PASSWORD=erin-local-password
# Production uses this separate bucket-scoped identity instead of root.
MINIO_APP_USER=erin-app
MINIO_APP_PASSWORD=erin-app-local-password
AWS_ACCESS_KEY_ID="${MINIO_ROOT_USER}"
AWS_SECRET_ACCESS_KEY="${MINIO_ROOT_PASSWORD}"
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=erin-private
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000/erin-private
AWS_USE_PATH_STYLE_ENDPOINT=true

DOCUMENTS_DISK=documents
PRIVATE_FILESYSTEM_DRIVER=s3
# Optional bucket prefix, never a local absolute filesystem path.
PRIVATE_FILESYSTEM_PREFIX=
DOCUMENTS_AWS_BUCKET="${AWS_BUCKET}"
DOCUMENTS_AWS_ENDPOINT="${AWS_ENDPOINT}"
DOCUMENTS_AWS_URL="${AWS_URL}"
DOCUMENTS_AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=erin
REVERB_APP_KEY=erin-local-key
REVERB_APP_SECRET=erin-local-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_ALLOWED_ORIGINS=localhost,127.0.0.1
REVERB_APP_RATE_LIMITING_ENABLED=true
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=60
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60
REVERB_APP_RATE_LIMIT_TERMINATE=true

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
VITE_BROADCAST_CONNECTION=reverb

# To use Pusher Channels instead of the local Reverb container:
# BROADCAST_CONNECTION=pusher
# VITE_BROADCAST_CONNECTION=pusher
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_HOST=
# PUSHER_PORT=443
# PUSHER_SCHEME=https
# PUSHER_APP_CLUSTER=mt1
# VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
# VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Stripe / Laravel Cashier. Product and Price IDs are created in Stripe and
# stored here; no product prices are hard-coded in the application.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE=300
STRIPE_MAX_NETWORK_RETRIES=2
STRIPE_PRODUCT_BASIC=
STRIPE_PRICE_BASIC=
STRIPE_PRODUCT_BUSINESS=
STRIPE_PRICE_BUSINESS=
STRIPE_PRODUCT_PREMIUM=
STRIPE_PRICE_PREMIUM=
STRIPE_PRODUCT_RECRUITER_SEAT=
STRIPE_PRICE_RECRUITER_SEAT=
STRIPE_PRICE_VISA_PACKAGE=
VITE_STRIPE_PUBLISHABLE_KEY="${STRIPE_PUBLISHABLE_KEY}"
CASHIER_PATH=billing
CASHIER_CURRENCY=eur
CASHIER_CURRENCY_LOCALE=de_DE
CASHIER_PAPER=A4

# Zammad support bridge. The token belongs to a dedicated agent account.
# Configure the webhook URL as /integrations/zammad/webhook and use the same
# HMAC-SHA1 signature token on both sides.
ZAMMAD_ENABLED=false
ZAMMAD_URL=
ZAMMAD_TOKEN=
ZAMMAD_GROUP=Users
ZAMMAD_WEBHOOK_SECRET=
# Optional separates outbound message markers from the webhook key. During a
# rotation, keep old keys comma-separated until all in-flight jobs are done.
ZAMMAD_MESSAGE_MARKER_SECRET=
ZAMMAD_PREVIOUS_MESSAGE_MARKER_SECRETS=
ZAMMAD_WEBHOOK_CALLBACK_URL="${APP_URL}/integrations/zammad/webhook"
ZAMMAD_ALLOW_LOCAL_HTTP=false
ZAMMAD_LOCAL_HTTP_HOSTS=
ZAMMAD_TIMEOUT=10
ZAMMAD_WEBHOOK_MAX_BYTES=2097152
ZAMMAD_RECONCILE_INITIAL_DELAY_SECONDS=30
ZAMMAD_RECONCILE_INTERVAL_SECONDS=15
ZAMMAD_RECONCILE_REQUIRED_MISSES=3
ZAMMAD_UNMATCHED_WEBHOOK_RETENTION_HOURS=24

# Support attachments are always private and remain unavailable until ClamAV
# marks them as clean.
SUPPORT_ATTACHMENT_DISK=private
SUPPORT_ATTACHMENT_MAX_FILES=8
SUPPORT_ATTACHMENT_MAX_KILOBYTES=10240
SUPPORT_ATTACHMENT_MAX_TOTAL_KILOBYTES=15360
SUPPORT_ATTACHMENT_URL_MINUTES=10
SUPPORT_ATTACHMENT_ORPHAN_GRACE_HOURS=24
SUPPORT_SYNC_LOCK_SECONDS=300
SUPPORT_SYNC_LOCK_RETRY_SECONDS=5

# Full-text search
SCOUT_DRIVER=meilisearch
SCOUT_PREFIX=erin_local_
SCOUT_QUEUE=true
SCOUT_AFTER_COMMIT=true
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=erin-local-master-key-change-me

# Private-file malware scanning
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=30

# Operational monitoring and retention. A value of 0 disables deletion until
# the responsible DPO/legal owner has approved the concrete retention policy.
ERIN_QUEUE_HEALTH_QUEUES=high,default,low
ERIN_QUEUE_MAX_PENDING=500
ERIN_QUEUE_MAX_FAILED=0
ERIN_RETENTION_LOGIN_HISTORY_DAYS=0
ERIN_RETENTION_READ_NOTIFICATION_DAYS=0
ERIN_RETENTION_ACTIVITY_DAYS=0
ERIN_RETENTION_CANDIDATE_IMPORT_DAYS=0
ERIN_RETENTION_FAILED_JOB_DAYS=0

# Structured evidence for the strict production-readiness gate. Identity values
# use "Vorname Nachname <person@organisation.tld>", dates use UTC ISO-8601 and
# references must be credential-free HTTPS URLs to immutable evidence.
ERIN_RELEASE_ID=
ERIN_RELEASE_COMMIT_SHA=
ERIN_RELEASE_PREPARED_BY=
ERIN_BACKUP_RESTORE_REFERENCE=
ERIN_BACKUP_RESTORE_VERIFIED_BY=
ERIN_BACKUP_RESTORE_VERIFIED_AT=
ERIN_BACKUP_DRILL_STARTED_AT=
ERIN_BACKUP_DRILL_COMPLETED_AT=
ERIN_BACKUP_DB_CREATED_AT=
ERIN_BACKUP_DB_LAST_RESTORED_RECORD_AT=
ERIN_BACKUP_DB_RESTORED_AT=
ERIN_BACKUP_OBJECT_CREATED_AT=
ERIN_BACKUP_OBJECT_LAST_RESTORED_RECORD_AT=
ERIN_BACKUP_OBJECT_RESTORED_AT=
ERIN_BACKUP_RESTORE_RELEASE_ID=
ERIN_BACKUP_DB_RPO_TARGET_MINUTES=
ERIN_BACKUP_DB_RPO_ACHIEVED_MINUTES=
ERIN_BACKUP_DB_RTO_TARGET_MINUTES=
ERIN_BACKUP_DB_RTO_ACHIEVED_MINUTES=
ERIN_BACKUP_OBJECT_RPO_TARGET_MINUTES=
ERIN_BACKUP_OBJECT_RPO_ACHIEVED_MINUTES=
ERIN_BACKUP_OBJECT_RTO_TARGET_MINUTES=
ERIN_BACKUP_OBJECT_RTO_ACHIEVED_MINUTES=
ERIN_BACKUP_ENCRYPTION_VERIFIED=false
ERIN_BACKUP_ISOLATION_VERIFIED=false
ERIN_BACKUP_SCOPE=
ERIN_BACKUP_PRODUCTION_GATE_ELIGIBLE=false
ERIN_BACKUP_INDEPENDENTLY_VERIFIED=false
ERIN_BACKUP_EVIDENCE_MAX_AGE_DAYS=90
ERIN_SECURITY_REVIEW_REFERENCE=
ERIN_SECURITY_REVIEWED_BY=
ERIN_SECURITY_REVIEWED_AT=
ERIN_SECURITY_REVIEW_RELEASE_ID=
ERIN_SECURITY_REVIEW_COMMIT_SHA=
ERIN_SECURITY_AUTOMATED_EVIDENCE_REFERENCE=
ERIN_SECURITY_OPEN_CRITICAL_FINDINGS=
ERIN_SECURITY_OPEN_HIGH_FINDINGS=
ERIN_SECURITY_INDEPENDENT_REVIEW_VERIFIED=false
ERIN_SECURITY_PENETRATION_TEST_VERIFIED=false
ERIN_SECURITY_EVIDENCE_MAX_AGE_DAYS=30
ERIN_DPO_APPROVAL_REFERENCE=
ERIN_DPO_APPROVED_BY=
ERIN_DPO_APPROVED_AT=
ERIN_DPO_APPROVAL_RELEASE_ID=
ERIN_DPO_APPROVAL_STATUS=
ERIN_DPO_AUTHORITY_VERIFIED=false
ERIN_DPO_EVIDENCE_MAX_AGE_DAYS=365
ERIN_LEGAL_APPROVAL_REFERENCE=
ERIN_LEGAL_APPROVED_BY=
ERIN_LEGAL_APPROVED_AT=
ERIN_LEGAL_APPROVAL_RELEASE_ID=
ERIN_LEGAL_APPROVAL_STATUS=
ERIN_LEGAL_AUTHORITY_VERIFIED=false
ERIN_LEGAL_EVIDENCE_MAX_AGE_DAYS=365
ERIN_PILOT_OWNER=
ERIN_PILOT_DEPUTY=
ERIN_PILOT_DECISION_BY=
ERIN_PILOT_DECISION_AT=
ERIN_PILOT_STARTED_AT=
ERIN_PILOT_RELEASE_ID=
ERIN_PILOT_PLAN_REFERENCE=
ERIN_PILOT_DECISION_REFERENCE=
ERIN_PILOT_ACCEPTANCE_REFERENCE=
ERIN_PILOT_ROLLBACK_REFERENCE=
ERIN_PILOT_STATUS=
ERIN_PILOT_SYNTHETIC=true
ERIN_PILOT_PARTICIPANT_CONSENT_VERIFIED=false
ERIN_PILOT_STOP_CRITERIA_TESTED=false
ERIN_PILOT_ROLLBACK_TESTED=false
ERIN_PILOT_EVIDENCE_MAX_AGE_DAYS=90
ERIN_GOVERNANCE_ATTESTATION_PATH=
ERIN_GOVERNANCE_TRUST_ROOT_PATH=
ERIN_GOVERNANCE_SECRET_ROOT=/run/secrets
ERIN_GOVERNANCE_ATTESTATION_MAX_LIFETIME_HOURS=168

# OpenAI Responses API. Keep document processing disabled until the EU
# endpoint and the required data controls have been contractually enabled.
OPENAI_API_KEY=
OPENAI_PROJECT=
OPENAI_ORGANIZATION=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_QUALITY_MODEL=gpt-5.6-terra
OPENAI_ECONOMY_MODEL=gpt-5.6-luna
OPENAI_TIMEOUT=90
OPENAI_STORE=false
OPENAI_EU_DATA_CONTROLS=false
OPENAI_DOCUMENT_AI_ENABLED=false

# LiveKit Cloud. Use an EU-pinned project in production.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL_MINUTES=10
LIVEKIT_E2EE_REQUIRED=true
LIVEKIT_REGION=eu
VITE_LIVEKIT_URL="${LIVEKIT_URL}"

# Browser push. Generate VAPID keys per environment and never rotate them
# without migrating existing subscriptions.
VAPID_SUBJECT=mailto:noreply@wannemueller.dev
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
WEBPUSH_ALLOWED_ENDPOINT_HOSTS=fcm.googleapis.com,android.googleapis.com,updates.push.services.mozilla.com,push.services.mozilla.com,web.push.apple.com,notify.windows.com
VITE_VAPID_PUBLIC_KEY="${VAPID_PUBLIC_KEY}"

# Development service ports
APP_PORT=8000
VITE_PORT=5173
MYSQL_FORWARD_PORT=3306
REDIS_FORWARD_PORT=6379
REVERB_FORWARD_PORT=8080
MEILISEARCH_FORWARD_PORT=7700
MINIO_FORWARD_PORT=9000
MINIO_CONSOLE_FORWARD_PORT=9001
MAILPIT_FORWARD_PORT=8025
NGINX_FORWARD_PORT=8081
